// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(uuid())
  first_name String    @db.VarChar(64)
  last_name  String    @db.VarChar(64)
  phone      String    @unique @db.VarChar(20)
  password   String
  birthday   DateTime? @db.Date
  photo      String?   @db.VarChar(500)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  role        Role         @relation(fields: [roleId], references: [id])
  roleId      String
  isSuperUser Boolean      @default(false) @map("is_super_user")
  assignments Assignment[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(64)
  description String?
  createdAt   DateTime @default(now())
  isSystem    Boolean  @default(false) @map("is_system")

  users       User[]
  permissions Permission[]

  @@map("roles")
}

model Region {
  id        String     @id @default(uuid())
  name      String     @unique @db.VarChar(64)
  districts District[]

  @@map("regions")
}

model District {
  id       String    @id @default(uuid())
  name     String    @db.VarChar(64)
  regionId String
  region   Region    @relation(fields: [regionId], references: [id])
  patients Patient[]

  @@unique([name, regionId])
  @@map("districts")
}

enum DocumentType {
  PASSPORT
  BIRTH_CERTIFICATE
  FOREIGN_PASSPORT
  RESIDENCE_PERMIT

  @@map("document_types")
}

enum BloodType {
  O_POSITIVE
  O_NEGATIVE
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE

  @@map("blood_types")
}

model Patient {
  id              String        @id @default(uuid())
  first_name      String        @db.VarChar(64)
  last_name       String        @db.VarChar(64)
  phone_number    String        @db.VarChar(15)
  gender          String        @db.VarChar(10)
  birth_date      DateTime      @db.Date
  address         String?       @db.VarChar(255)
  blood_type      BloodType?    @default(O_POSITIVE)
  document_type   DocumentType?
  document_series String?       @db.VarChar(10)
  document_number String?       @db.VarChar(20)
  pinfl           String?       @unique @db.VarChar(14)
  district        District      @relation(fields: [districtId], references: [id])
  districtId      String
  payments        Payment[]
  appointments    Appointment[]
  medicalCards    MedicalCard003[]
  cases           PatientCase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("patients")
}

model MedicalCard003 {
  id String @id @default(uuid())

  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId String

  admissionDate DateTime  @db.Date
  dischargeDate DateTime? @db.Date

  wardNumber     String? @db.VarChar(20)
  departmentName String? @db.VarChar(128)
  doctorName     String? @db.VarChar(128)
  nurseName      String? @db.VarChar(128)

  complaints    String? @db.Text
  anamnesis     String? @db.Text
  lifeAnamnesis String? @db.Text

  diagnosisInitial String? @db.VarChar(500)
  diagnosisFinal   String? @db.VarChar(500)

  treatment  String? @db.Text
  dailyNotes Json?   @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("medical_cards_003")
}

model Department {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(64)
  description String?
  price       Float?

  parentId String?
  parent   Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentTree")

  payments    Payment[]
  assignments Assignment[]

  @@map("departments")
}

// ─── Assignments ────────────────────────────────────────────────────────────

enum RoomType {
  WARD // Yotoqxona
  EXAMINATION // Ko'rik xonasi

  @@map("room_types")
}

/// Binodagi xonalar (220-xona, Operatsion xona, va h.k.)
model Room {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(64)
  capacity    Int      @default(1)
  description String?
  roomType    RoomType @map("room_type")

  assignments Assignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rooms")
}

/// Ish soati — Assignment ga biriktirilgan haftalik jadval qatori
model Schedule {
  id String @id @default(uuid())

  /// 1=Dushanba, 2=Seshanba, ..., 7=Yakshanba
  dayOfWeek Int

  startTime String @db.VarChar(5) // "09:00"
  endTime   String @db.VarChar(5) // "18:00"

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String

  @@map("schedules")
}

/// Xodimni (shifokor / hamshira) departmentga va xonaga biriktirish
model Assignment {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String

  room   Room?   @relation(fields: [roomId], references: [id])
  roomId String?

  schedules    Schedule[]
  appointments Appointment[]
  payments     Payment[]
  caseSteps    CaseStep[]

  /// Assignment faolmi yoki yo'qmi
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, departmentId])
  @@map("assignments")
}

/// Rol uchun ruxsat: qaysi HTTP method + path ga kirish joiz
model Permission {
  id     String @id @default(uuid())
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  /// HTTP method: GET, POST, PATCH, DELETE
  method String @db.VarChar(10)

  /// Normalized path: /api/users, /api/users/:id
  path String @db.VarChar(200)

  @@unique([roleId, method, path])
  @@map("permissions")
}

model Payment {
  id     String         @id @default(uuid())
  amount Float
  method PaymentMethod?
  status PaymentStatus  @default(UNPAID)

  patient   Patient @relation(fields: [patientId], references: [id])
  patientId String

  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String

  assignment   Assignment? @relation(fields: [assignmentId], references: [id])
  assignmentId String?

  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  appointmentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PAYPAL

  @@map("payment_methods")
}

enum PaymentStatus {
  PAID
  UNPAID

  @@map("payment_statuses")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED

  @@map("appointment_statuses")
}

model Appointment {
  id       String            @id @default(uuid())
  dateTime DateTime
  status   AppointmentStatus @default(PENDING)

  patient   Patient @relation(fields: [patientId], references: [id])
  patientId String

  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  assignmentId String

  payments     Payment[]
  files        AppointmentFile[]
  prescription Prescription?
  caseStep     CaseStep?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointments")
}

model AppointmentFile {
  id            String      @id @default(uuid())
  name          String
  url           String
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@map("appointment_files")
}

// ─── Medicines & Prescriptions ───────────────────────────────────────────────

/// Dori nomi (global katalog)
model Medicine {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(128)
  createdAt DateTime @default(now())

  prescriptionItems PrescriptionItem[]

  @@map("medicines")
}

enum MealRelation {
  BEFORE_MEAL
  AFTER_MEAL
  WITH_MEAL
  AT_SPECIFIC_TIME

  @@map("meal_relations")
}

/// Appointment uchun recept (1:1). appointmentId — old path, caseStepId — new path.
model Prescription {
  id            String      @id @default(uuid())
  appointmentId String?     @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  caseStepId    String?     @unique
  caseStep      CaseStep?   @relation(fields: [caseStepId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items PrescriptionItem[]

  @@map("prescriptions")
}

/// Receptdagi bitta dori satri
model PrescriptionItem {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  medicineId String
  medicine   Medicine @relation(fields: [medicineId], references: [id])

  dosage       String       @db.VarChar(64)
  frequency    Int
  startDate    DateTime     @db.Date
  endDate      DateTime     @db.Date
  mealRelation MealRelation
  specificTime String?      @db.VarChar(5)
  note         String?

  @@map("prescription_items")
}

// ─── Patient Case Workflow ───────────────────────────────────────────────────

enum CaseStatus {
  ACTIVE
  COMPLETED
  CANCELLED

  @@map("case_statuses")
}

enum CaseStepType {
  CHECKIN
  CONSULTATION
  LAB
  PROCEDURE
  REFERRAL
  DISCHARGE

  @@map("case_step_types")
}

enum CaseStepStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED

  @@map("case_step_statuses")
}

model PatientCase {
  id             String      @id @default(uuid())
  patient        Patient     @relation(fields: [patientId], references: [id])
  patientId      String
  status         CaseStatus  @default(ACTIVE)
  chiefComplaint String?     @db.Text
  openedAt       DateTime    @default(now())
  closedAt       DateTime?
  steps          CaseStep[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("patient_cases")
}

model CaseStep {
  id            String         @id @default(uuid())
  case          PatientCase    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId        String
  type          CaseStepType
  status        CaseStepStatus @default(PENDING)
  assignment    Assignment?    @relation(fields: [assignmentId], references: [id])
  assignmentId  String?
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id])
  appointmentId String?        @unique
  note          String?        @db.Text
  completedAt   DateTime?
  prescription  Prescription?

  createdAt DateTime @default(now())

  @@map("case_steps")
}
